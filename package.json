{
  "name": "health-app-root",
  "version": "1.0.0",
  "description": "Root package for MERN deployment",
  "scripts": {
    "start": "cd backend && node index.js",
    "install-backend": "cd backend && npm install",
    "install-frontend": "cd frontend && npm install",
    "build-frontend": "cd frontend && npm run build",
    "render-build": "npm run install-backend && npm run install-frontend && npm run build-frontend",
    "render-postbuild": "npm run render-build"
  }
}
